# ── Data: per-problem checkpoint directories ─────────────────────────────────
# Checkpoint dirs hold one file per problem and are regenerated by the pipeline.
# Only the aggregated *.json files next to them are tracked.
# Covers three layouts:
#   (a) model/neutral/humaneval*/       – neutral generations (new layout)
#   (b) model/humaneval*/               – Qwen runs (old layout, no neutral/ subdir)
#   (c) model/behavior/humaneval/       – misaligned behavior generations
data/generations/*/neutral/humaneval/
data/generations/*/neutral/humaneval__*/
data/generations/*/neutral/humaneval_run_*/
data/generations/*/neutral/mbpp/
data/generations/*/neutral/mbpp__*/
data/generations/*/neutral/mbpp_run_*/
data/generations/*/humaneval/
data/generations/*/humaneval__*/
data/generations/*/humaneval_run_*/
data/generations/*/mbpp/
data/generations/*/mbpp__*/
data/generations/*/mbpp_run_*/
data/generations/*/*/humaneval/
data/generations/*/*/mbpp/

# Steered test-mode files (use full-mode humaneval.json for analysis)
data/generations/*_steered/*/*/test_*.json
